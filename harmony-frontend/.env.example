# Frontend canonical origin used for absolute public URLs and metadata.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Public backend API origin used by browser and server-side frontend code.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Shared backend access-token secret used by Edge middleware to verify
# auth_token JWT signatures before protected routes are rendered.
JWT_ACCESS_SECRET=change-me-access-secret

# Pixabay API key for the GIF picker (https://pixabay.com/api/docs/).
# Without this the GIF button returns a 503; the rest of the app is unaffected.
PIXABAY_API_KEY=
